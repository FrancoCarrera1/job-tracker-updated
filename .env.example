# --- Database ---
POSTGRES_USER=jobtracker
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jobtracker
DATABASE_URL=postgresql+psycopg://jobtracker:changeme@postgres:5432/jobtracker

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- App ---
APP_ENV=local
APP_SECRET_KEY=replace-with-long-random-string
APP_BASE_URL=http://localhost:8000
DASHBOARD_BASE_URL=http://localhost:5173

# --- Gmail OAuth (https://console.cloud.google.com/) ---
# Create an OAuth 2.0 Client ID (Desktop app or Web app), add the redirect URI:
# http://localhost:8000/api/auth/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback

# --- LLM (pluggable) ---
# Set ONE provider; the others can stay blank.
LLM_PROVIDER=anthropic   # anthropic | openai | ollama
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
# For OpenAI-compatible local inference servers, set OPENAI_BASE_URL to the
# full /v1 endpoint and you can leave OPENAI_API_KEY blank.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Telegram ---
# Talk to @BotFather to create a bot; send /start to your bot, then visit
# https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Automation safety ---
DRY_RUN=true
PER_JOB_APPROVAL=true
KILL_SWITCH=false
MAX_APPS_PER_DAY=20
MAX_APPS_PER_PLATFORM_PER_DAY=10
MAX_APPS_PER_COMPANY_PER_DAY=1

# --- Source opt-in (ToS-sensitive) ---
ENABLE_LINKEDIN=false
ENABLE_INDEED=false
ENABLE_GREENHOUSE=true
ENABLE_LEVER=true
ENABLE_CLEARANCEJOBS=true

# --- Profile defaults (override per profile in DB) ---
DEFAULT_LOCATION=San Antonio, TX
DEFAULT_SALARY_MIN=95000
DEFAULT_SALARY_MAX=140000
